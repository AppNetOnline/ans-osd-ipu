<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ANS IPU Console"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize">

    <Window.Resources>

        <!-- Header icon-button style (minimize / close) -->
        <Style x:Key="HeaderBtnStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="#C8C8C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button — turns red on hover -->
        <Style x:Key="CloseBtnStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E50019"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost button used in progress footer and status bar -->
        <Style x:Key="GhostBtnStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#C8C8C8"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button (Start Upgrade) -->
        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C8001A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary outline button (Repair / Cancel in overlay) -->
        <Style x:Key="SecondaryBtnStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="#C8C8C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark-themed CheckBox -->
        <Style x:Key="DarkCheckStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="ChkBox"
                                    Width="16" Height="16"
                                    Background="#1A1A1A"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="ChkMark"
                                           Text="&#x2713;"
                                           Foreground="#E50019"
                                           FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ChkBox" Property="BorderBrush" Value="#E50019"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C8C8C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBoxItem style -->
        <Style x:Key="DarkComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#C8C8C8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#E50019"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox style with fully dark popup -->
        <Style x:Key="DarkComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#C8C8C8"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Box background + border -->
                            <Border x:Name="CboBd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"/>
                            <!-- Selected item text -->
                            <ContentPresenter x:Name="CboContent"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,32,0"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                            <!-- Dropdown arrow -->
                            <Path x:Name="Arrow"
                                  Data="M0,0 L6,6 L12,0"
                                  Stroke="#555555" StrokeThickness="1.5"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  IsHitTestVisible="False"/>
                            <!-- Transparent toggle button to capture clicks -->
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#1A1A1A"
                                        BorderBrush="#333333"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        MaxHeight="300">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="4" Opacity="0.6"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CboBd" Property="BorderBrush" Value="#555555"/>
                                <Setter TargetName="Arrow" Property="Stroke" Value="#C8C8C8"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="CboBd" Property="BorderBrush" Value="#E50019"/>
                                <Setter TargetName="Arrow" Property="Stroke" Value="#E50019"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="10"
            Background="#0E0E0E"
            BorderBrush="#2A2A2A"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="50" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════════ HEADER -->
            <Border Grid.Row="0"
                    Background="#141414"
                    BorderBrush="#222222"
                    BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- ANS logo mark -->
                    <Viewbox Grid.Column="0" Width="34" Height="34" Margin="0,0,14,0">
                        <Canvas Width="110" Height="110">
                            <Path Fill="#E50019"
                                  Data="M102.72,55.053v-40.2a7.519,7.519,0,1,0-9.1-5.5,7.66,7.66,0,0,0,5.5,5.5v40.4a12.578,12.578,0,0,0-5.1,2.1l-18.5-18.5a7.532,7.532,0,1,0-10.4,2.3,7.36,7.36,0,0,0,7.7.2l18.4,18.4a13.279,13.279,0,0,0-3,7.2H14.82a7.519,7.519,0,1,0-5.5,9.1,7.66,7.66,0,0,0,5.5-5.5h73.6a12.939,12.939,0,0,0,2.6,5.7l-19.8,19.8a7.517,7.517,0,1,0,2.2,10.4,7.59,7.59,0,0,0,.3-7.7l20-20a13.241,13.241,0,1,0,15.6-21.4,15.335,15.335,0,0,0-6.6-2.3Zm-95.2,17.6a3.9,3.9,0,1,1,3.9-3.9A3.9,3.9,0,0,1,7.52,72.653Zm89.5-65.1a3.9,3.9,0,1,1,3.9,3.9,3.97,3.97,0,0,1-3.9-3.9Zm-31.7,27.3a3.9,3.9,0,0,1,3.9-3.9,3.842,3.842,0,0,1,3.9,3.9,3.9,3.9,0,0,1-3.9,3.9,3.97,3.97,0,0,1-3.9-3.9Zm1.8,71.5a3.9,3.9,0,1,1,3.9-3.9,3.97,3.97,0,0,1-3.9,3.9Zm34.3-28.6a9.6,9.6,0,1,1,9.6-9.6h0a9.539,9.539,0,0,1-9.6,9.6Z"/>
                        </Canvas>
                    </Viewbox>

                    <!-- Title -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Appalachian"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="Normal"
                                       Foreground="#96999C"/>
                            <TextBlock Text=" Network Services"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#E8E8E8"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="IPU"
                                       FontFamily="Cascadia Code, Consolas" FontSize="11"
                                       Foreground="#E50019"/>
                            <TextBlock Text=" / In-Place Upgrade Console"
                                       FontFamily="Cascadia Code, Consolas" FontSize="11"
                                       Foreground="#3A3A3A"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Status + Minimize + Close -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#333333" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtStatusLabel"
                                   Text="Initializing"
                                   FontFamily="Cascadia Code, Consolas" FontSize="12"
                                   Foreground="#555555" Margin="0,0,16,0"/>
                        <Button x:Name="BtnMinimize"
                                Content="&#x2212;"
                                Width="26" Height="26" Cursor="Hand" ToolTip="Minimize"
                                FontFamily="Segoe UI" FontSize="14"
                                Foreground="#555555" Background="Transparent" BorderThickness="0"
                                Style="{StaticResource HeaderBtnStyle}"/>
                        <Button x:Name="BtnClose"
                                Content="&#x2715;"
                                Width="26" Height="26" Cursor="Hand" ToolTip="Close"
                                FontFamily="Segoe UI" FontSize="12"
                                Foreground="#555555" Background="Transparent" BorderThickness="0"
                                Margin="4,0,0,0"
                                Style="{StaticResource CloseBtnStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ LOG -->
            <Grid Grid.Row="1" Background="#0A0A0A">
                <ScrollViewer x:Name="LogScroller"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent">
                    <RichTextBox x:Name="RtbLog"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="12"
                                 Foreground="#C8C8C8"
                                 Padding="24,16"
                                 HorizontalAlignment="Stretch"
                                 IsDocumentEnabled="True"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </ScrollViewer>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════ PROGRESS -->
            <Border Grid.Row="2"
                    Background="#141414"
                    BorderBrush="#222222"
                    BorderThickness="0,1,0,0"
                    Padding="24,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Label row -->
                    <Grid Grid.Row="0" Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtProgress"
                                   Text="Awaiting upgrade..."
                                   FontFamily="Cascadia Code, Consolas" FontSize="11"
                                   Foreground="#555555"/>
                        <TextBlock x:Name="TxtPercent"
                                   Grid.Column="1" Text="0%"
                                   FontFamily="Cascadia Code, Consolas" FontSize="11"
                                   Foreground="#555555"/>
                    </Grid>

                    <!-- Progress bar -->
                    <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="3">
                        <Border x:Name="ProgressFill"
                                Background="#E50019" CornerRadius="3"
                                HorizontalAlignment="Left" Width="0"/>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,10,0,2">
                        <Button x:Name="BtnRepair"
                                Content="Repair Failed Upgrade"
                                Height="26" Padding="14,0"
                                Cursor="Hand"
                                FontFamily="Cascadia Code, Consolas" FontSize="10"
                                Foreground="#C8820A"
                                Background="Transparent"
                                BorderBrush="#3A2A0A" BorderThickness="1"
                                Margin="0,0,8,0"
                                Style="{StaticResource GhostBtnStyle}"
                                ToolTip="Run Start-Repair.ps1 to fix common upgrade failures"/>
                        <Button x:Name="BtnCancel"
                                Content="Cancel"
                                Height="26" Padding="14,0"
                                Cursor="Hand"
                                FontFamily="Cascadia Code, Consolas" FontSize="10"
                                Foreground="#555555"
                                Background="Transparent"
                                BorderBrush="#2A2A2A" BorderThickness="1"
                                Style="{StaticResource GhostBtnStyle}"
                                ToolTip="Cancel the upgrade and close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════ STATUS BAR -->
            <Border Grid.Row="3"
                    Background="#111111"
                    BorderBrush="#1E1E1E"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10"
                    Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Appalachian Network Services - appnetonline.com"
                               FontFamily="Cascadia Code, Consolas" FontSize="10"
                               Foreground="#2A2A2A" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtClock"
                               Grid.Column="1"
                               FontFamily="Cascadia Code, Consolas" FontSize="10"
                               Foreground="#2A2A2A" VerticalAlignment="Center"
                               Margin="0,0,20,0"/>
                    <TextBlock x:Name="TxtVersion"
                               Grid.Column="2" Text="v1.0"
                               FontFamily="Cascadia Code, Consolas" FontSize="10"
                               Foreground="#2A2A2A" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════ CONFIG OVERLAY -->
            <!-- Shown on load; hidden when upgrade starts -->
            <Grid x:Name="ConfigOverlay"
                  Grid.RowSpan="4"
                  Background="#D90A0A0A"
                  Visibility="Visible"
                  Panel.ZIndex="10">
                <Border Background="#141414"
                        BorderBrush="#2A2A2A" BorderThickness="1"
                        CornerRadius="8"
                        MaxWidth="540"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="32,28">
                    <StackPanel>

                        <!-- ANS logo + title — centered, matching header -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,16">
                            <Viewbox Width="34" Height="34" Margin="0,0,14,0">
                                <Canvas Width="110" Height="110">
                                    <Path Fill="#E50019"
                                          Data="M102.72,55.053v-40.2a7.519,7.519,0,1,0-9.1-5.5,7.66,7.66,0,0,0,5.5,5.5v40.4a12.578,12.578,0,0,0-5.1,2.1l-18.5-18.5a7.532,7.532,0,1,0-10.4,2.3,7.36,7.36,0,0,0,7.7.2l18.4,18.4a13.279,13.279,0,0,0-3,7.2H14.82a7.519,7.519,0,1,0-5.5,9.1,7.66,7.66,0,0,0,5.5-5.5h73.6a12.939,12.939,0,0,0,2.6,5.7l-19.8,19.8a7.517,7.517,0,1,0,2.2,10.4,7.59,7.59,0,0,0,.3-7.7l20-20a13.241,13.241,0,1,0,15.6-21.4,15.335,15.335,0,0,0-6.6-2.3Zm-95.2,17.6a3.9,3.9,0,1,1,3.9-3.9A3.9,3.9,0,0,1,7.52,72.653Zm89.5-65.1a3.9,3.9,0,1,1,3.9,3.9,3.97,3.97,0,0,1-3.9-3.9Zm-31.7,27.3a3.9,3.9,0,0,1,3.9-3.9,3.842,3.842,0,0,1,3.9,3.9,3.9,3.9,0,0,1-3.9,3.9,3.97,3.97,0,0,1-3.9-3.9Zm1.8,71.5a3.9,3.9,0,1,1,3.9-3.9,3.97,3.97,0,0,1-3.9,3.9Zm34.3-28.6a9.6,9.6,0,1,1,9.6-9.6h0a9.539,9.539,0,0,1-9.6,9.6Z"/>
                                </Canvas>
                            </Viewbox>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Appalachian"
                                               FontFamily="Segoe UI" FontSize="13" FontWeight="Normal"
                                               Foreground="#96999C"/>
                                    <TextBlock Text=" Network Services"
                                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#E8E8E8"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="IPU"
                                               FontFamily="Cascadia Code, Consolas" FontSize="11"
                                               Foreground="#E50019"/>
                                    <TextBlock Text=" / In-Place Upgrade Console"
                                               FontFamily="Cascadia Code, Consolas" FontSize="11"
                                               Foreground="#3A3A3A"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Accent bar -->
                        <Border Background="#E50019" Height="2" CornerRadius="1" Margin="0,0,0,20"/>

                        <!-- Heading -->
                        <TextBlock Text="Configure Upgrade"
                                   FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#E8E8E8" Margin="0,0,0,4"/>
                        <TextBlock Text="Choose a target OS and set options, then click Start Upgrade."
                                   FontFamily="Segoe UI" FontSize="12"
                                   Foreground="#555555" Margin="0,0,0,22" TextWrapping="Wrap"/>

                        <!-- Target OS -->
                        <TextBlock Text="TARGET OS"
                                   FontFamily="Cascadia Code, Consolas" FontSize="10"
                                   Foreground="#3A3A3A" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CboOSName"
                                  Height="32" Margin="0,0,0,20"
                                  Style="{StaticResource DarkComboStyle}">
                            <ComboBoxItem Content="Windows 11 25H2 x64"    IsSelected="True"/>
                            <ComboBoxItem Content="Windows 11 25H2 ARM64"/>
                            <ComboBoxItem Content="Windows 11 24H2 x64"/>
                            <ComboBoxItem Content="Windows 11 24H2 ARM64"/>
                            <ComboBoxItem Content="Windows 11 23H2 x64"/>
                            <ComboBoxItem Content="Windows 11 23H2 ARM64"/>
                            <ComboBoxItem Content="Windows 11 22H2 x64"/>
                            <ComboBoxItem Content="Windows 11 21H2 x64"/>
                            <ComboBoxItem Content="Windows 10 22H2 x64"/>
                            <ComboBoxItem Content="Windows 10 22H2 ARM64"/>
                        </ComboBox>

                        <!-- Options -->
                        <TextBlock Text="OPTIONS"
                                   FontFamily="Cascadia Code, Consolas" FontSize="10"
                                   Foreground="#3A3A3A" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ChkSilent"    IsChecked="True"  Style="{StaticResource DarkCheckStyle}">
                            <StackPanel>
                                <TextBlock Text="Silent Installation"          Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="13"/>
                                <TextBlock Text="Suppresses all Windows Setup UI"  Foreground="#3A3A3A" FontFamily="Segoe UI" FontSize="11"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="ChkNoReboot"  IsChecked="False" Style="{StaticResource DarkCheckStyle}">
                            <StackPanel>
                                <TextBlock Text="Skip Reboot (NoReboot)"       Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="13"/>
                                <TextBlock Text="Setup completes down-level phase but does not restart" Foreground="#3A3A3A" FontFamily="Segoe UI" FontSize="11"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="ChkSkipDriverPack" IsChecked="False" Style="{StaticResource DarkCheckStyle}">
                            <StackPanel>
                                <TextBlock Text="Skip Driver Pack Download"    Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="13"/>
                                <TextBlock Text="Skips driver pack download and integration" Foreground="#3A3A3A" FontFamily="Segoe UI" FontSize="11"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="ChkDownloadOnly" IsChecked="False" Style="{StaticResource DarkCheckStyle}">
                            <StackPanel>
                                <TextBlock Text="Download Only"                Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="13"/>
                                <TextBlock Text="Downloads ESD and drivers only; does not launch Setup" Foreground="#3A3A3A" FontFamily="Segoe UI" FontSize="11"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="ChkDynamicUpdate" IsChecked="False" Style="{StaticResource DarkCheckStyle}" Margin="0,5,0,24">
                            <StackPanel>
                                <TextBlock Text="Allow Dynamic Updates"        Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="13"/>
                                <TextBlock Text="Allows Windows Setup to pull updates from Windows Update" Foreground="#3A3A3A" FontFamily="Segoe UI" FontSize="11"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- Buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnStartUpgrade"
                                    Grid.Column="0"
                                    Content="Start Upgrade"
                                    Height="38" Margin="0,0,10,0"
                                    Cursor="Hand"
                                    FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                    Foreground="#FFFFFF" Background="#E50019" BorderThickness="0"
                                    Style="{StaticResource PrimaryBtnStyle}"/>

                            <Button x:Name="BtnRepairOverlay"
                                    Grid.Column="1"
                                    Content="Repair"
                                    Height="38" Width="100" Margin="0,0,10,0"
                                    Cursor="Hand"
                                    FontFamily="Segoe UI" FontSize="13"
                                    Foreground="#C8820A"
                                    Background="Transparent"
                                    BorderBrush="#3A2A0A" BorderThickness="1"
                                    Style="{StaticResource SecondaryBtnStyle}"
                                    ToolTip="Run Start-Repair.ps1 to remediate a prior failed upgrade"/>

                            <Button x:Name="BtnCancelOverlay"
                                    Grid.Column="2"
                                    Content="Cancel"
                                    Height="38" Width="100"
                                    Cursor="Hand"
                                    FontFamily="Segoe UI" FontSize="13"
                                    Foreground="#555555"
                                    Background="Transparent"
                                    BorderBrush="#2A2A2A" BorderThickness="1"
                                    Style="{StaticResource SecondaryBtnStyle}"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
